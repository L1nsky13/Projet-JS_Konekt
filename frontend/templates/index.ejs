<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Konekt Handball Kits</title>
  <link rel="stylesheet" href="/assets/css/style.css" />
  <link rel="stylesheet" href="/assets/css/header.css" />
  <link rel="stylesheet" href="/assets/css/footer.css" />
</head>
<body>
  <header class="navbar">
    <div class="navbar__inner">

      <a href="/" class="navbar__logo">
        <img src="/assets/img/konekt.png" alt="Konekt" />
      </a>

      <nav class="navbar__nav" id="nav-menu">

        <!-- ── EHF Champions League — dropdown EJS ── -->
        <div class="nav-item">
          <div class="navbar__link">
            EHF Champions League
            <svg class="nav-arrow" viewBox="0 0 10 6" width="10" height="6">
              <path d="M0 0l5 6 5-6z" fill="currentColor"/>
            </svg>
          </div>
          <div class="dropdown">
            <div class="dropdown__inner">
              <% clubsEhf.forEach(function(club) { %>
                <a
                  href="/products?club=<%= encodeURIComponent(club.nom) %>"
                  class="dropdown__link"
                >
                  <%= club.nom %>
                </a>
              <% }) %>
            </div>
          </div>
        </div>

        <!-- ── Liqui Moly StarLigue — dropdown EJS ── -->
        <div class="nav-item">
          <div class="navbar__link">
            Liqui Moly StarLigue
            <svg class="nav-arrow" viewBox="0 0 10 6" width="10" height="6">
              <path d="M0 0l5 6 5-6z" fill="currentColor"/>
            </svg>
          </div>
          <div class="dropdown">
            <div class="dropdown__inner">
              <% clubsStarligue.forEach(function(club) { %>
                <a
                  href="/products?club=<%= encodeURIComponent(club.nom) %>"
                  class="dropdown__link"
                >
                  <%= club.nom %>
                </a>
              <% }) %>
            </div>
          </div>
        </div>

        <!-- ── Liens simples ── -->
        <a href="/products?club=France" class="navbar__link">France</a>
        <a href="/products?club=Allemagne" class="navbar__link">Allemagne</a>

      </nav>

      <div class="navbar__actions">

        <button class="navbar__icon-btn" id="btn-search" aria-label="Rechercher">
          <img src="/assets/icons/search.png" alt="Rechercher" />
        </button>

        <a href="/cart" class="navbar__icon-btn" aria-label="Panier">
          <img src="/assets/icons/panier.png" alt="Panier" />
          <span class="navbar__badge" id="cart-count">0</span>
        </a>

        <a href="/favorites" class="navbar__icon-btn" aria-label="Favoris">
          <img src="/assets/icons/favori.png" alt="Favoris" />
          <span class="navbar__badge" id="fav-count">0</span>
        </a>

        <button class="navbar__burger" id="btn-burger" aria-label="Menu">
          <span></span><span></span><span></span>
        </button>

      </div>
    </div>

    <!-- Barre de recherche -->
    <div class="search-bar" id="search-bar">
      <div class="search-bar__inner">
        <img src="/assets/icons/search.png" alt="" class="search-bar__icon" id="btn-search-submit" />
        <input
          type="text"
          id="search-input"
          class="search-bar__input"
          placeholder="Rechercher un club, une sélection, une compétition…"
          autocomplete="off"
        />
        <button class="search-bar__close" id="btn-search-close" aria-label="Fermer">✕</button>
      </div>
    </div>
  </header>

  <!-- Hero -->
  <section class="hero">
    <img src="/assets/img/konekt-desktop.png" alt="Konekt — Maillots de Handball" />
  </section>

  <!-- Défilement logos clubs -->
  <section class="clubs">
    <div class="clubs-track">
      <div><img src="/assets/img/FC_Barcelona.png" alt="Logo FC Barcelone"></div>
      <div><img src="/assets/img/Fuchse_Berlin.png" alt="Logo Fuchse Berlin"></div>
      <div><img src="/assets/img/SC_Magdeburg.png" alt="Logo SC Magdeburg"></div>
      <div><img src="/assets/img/Aalborg.png" alt="Logo Aalborg"></div>
      <div><img src="/assets/img/Wisla_Plock.png" alt="Logo Wisla Plock"></div>
      <div><img src="/assets/img/Kielce.png" alt="Logo Kielce"></div>
      <div><img src="/assets/img/HBC_Nantes.png" alt="Logo HBC Nantes"></div>
      <div><img src="/assets/img/PSG_Handball.png" alt="Logo PSG Handball"></div>
      <div><img src="/assets/img/Veszprém.png" alt="Logo Veszprém"></div>
      <div><img src="/assets/img/Sporting.png" alt="Logo Sporting"></div>
      <div><img src="/assets/img/GOG.png" alt="Logo GOG"></div>
      <div><img src="/assets/img/Szeged.png" alt="Logo Szeged"></div>
      <!-- Doublon pour l'effet défilement infini -->
      <div><img src="/assets/img/FC_Barcelona.png" alt="Logo FC Barcelone"></div>
      <div><img src="/assets/img/Fuchse_Berlin.png" alt="Logo Fuchse Berlin"></div>
      <div><img src="/assets/img/SC_Magdeburg.png" alt="Logo SC Magdeburg"></div>
      <div><img src="/assets/img/Aalborg.png" alt="Logo Aalborg"></div>
      <div><img src="/assets/img/Wisla_Plock.png" alt="Logo Wisla Plock"></div>
      <div><img src="/assets/img/Kielce.png" alt="Logo Kielce"></div>
      <div><img src="/assets/img/HBC_Nantes.png" alt="Logo HBC Nantes"></div>
      <div><img src="/assets/img/PSG_Handball.png" alt="Logo PSG Handball"></div>
      <div><img src="/assets/img/Veszprém.png" alt="Logo Veszprém"></div>
      <div><img src="/assets/img/Sporting.png" alt="Logo Sporting"></div>
      <div><img src="/assets/img/GOG.png" alt="Logo GOG"></div>
      <div><img src="/assets/img/Szeged.png" alt="Logo Szeged"></div>
    </div>
  </section>

  <!-- Catégories -->
  <section class="categories">
    <div class="category-card">
      <a href="/products?competition=EHF+Champions+League" class="category-card__link">
        <img src="/assets/img/ehf.png" alt="Logo EHF Champions League" />
        <p>Maillots EHF Champions League</p>
      </a>
    </div>
    <div class="category-card">
      <a href="/products?competition=Liqui+Moly+Starligue" class="category-card__link">
        <img src="/assets/img/lnh.png" alt="Logo Liqui Moly StarLigue" />
        <p>Maillots Liqui Moly StarLigue</p>
      </a>
    </div>
    <div class="category-card">
      <a href="/products?club=France" class="category-card__link">
        <img src="/assets/img/france.png" alt="Equipe de France" />
        <p>Maillots de l'Équipe de France</p>
      </a>
    </div>
    <div class="category-card">
      <a href="/products?club=Allemagne" class="category-card__link">
        <img src="/assets/img/allemagne.png" alt="Equipe d'Allemagne" />
        <p>Maillots de l'Équipe d'Allemagne</p>
      </a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer__inner">
      <div class="footer__brand">
        <img src="/assets/img/konekt.png" alt="Konekt" class="footer__logo" />
        <p class="footer__tagline">L'élite du handball, à portée de main.</p>
      </div>
      <div class="footer__links">
        <span class="footer__col-title">Catégories</span>
        <a href="/products?competition=EHF+Champions+League">EHF Champions League</a>
        <a href="/products?competition=Liqui+Moly+Starligue">Liqui Moly StarLigue</a>
        <a href="/products?club=France">Équipe de France</a>
        <a href="/products?club=Allemagne">Équipe d'Allemagne</a>
      </div>
      <div class="footer__links">
        <span class="footer__col-title">Mon compte</span>
        <a href="/cart">Mon panier</a>
        <a href="/favorites">Mes favoris</a>
      </div>
    </div>
    <div class="footer__bottom">
      <p>© Konekt Handball Kits 2026. Tous droits réservés.</p>
    </div>
  </footer>

  <script src="/src/script.js"></script>
</body>
</html>