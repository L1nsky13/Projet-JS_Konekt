<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Konekt Handball Kits — Catalogue</title>
  <link rel="stylesheet" href="/assets/css/header.css" />
  <link rel="stylesheet" href="/assets/css/footer.css" />
  <link rel="stylesheet" href="/assets/css/products.css" />
</head>
<body>
  <header class="navbar">
    <div class="navbar__inner">

      <a href="/" class="navbar__logo">
        <img src="/assets/img/konekt.png" alt="Konekt" />
      </a>

      <nav class="navbar__nav" id="nav-menu">

        <div class="nav-item">
          <div class="navbar__link">
            EHF Champions League
            <svg class="nav-arrow" viewBox="0 0 10 6" width="10" height="6">
              <path d="M0 0l5 6 5-6z" fill="currentColor"/>
            </svg>
          </div>
          <div class="dropdown">
            <div class="dropdown__inner">
              <% clubsEhf.forEach(function(club) { %>
                <a href="/products?club=<%= encodeURIComponent(club.nom) %>" class="dropdown__link">
                  <%= club.nom %>
                </a>
              <% }) %>
            </div>
          </div>
        </div>

        <div class="nav-item">
          <div class="navbar__link">
            Liqui Moly StarLigue
            <svg class="nav-arrow" viewBox="0 0 10 6" width="10" height="6">
              <path d="M0 0l5 6 5-6z" fill="currentColor"/>
            </svg>
          </div>
          <div class="dropdown">
            <div class="dropdown__inner">
              <% clubsStarligue.forEach(function(club) { %>
                <a href="/products?club=<%= encodeURIComponent(club.nom) %>" class="dropdown__link">
                  <%= club.nom %>
                </a>
              <% }) %>
            </div>
          </div>
        </div>

        <a href="/products?club=France" class="navbar__link">France</a>
        <a href="/products?club=Allemagne" class="navbar__link">Allemagne</a>

      </nav>

      <div class="navbar__actions">
        <button class="navbar__icon-btn" id="btn-search" aria-label="Rechercher">
          <img src="/assets/icons/search.png" alt="Rechercher" />
        </button>
        <a href="/cart" class="navbar__icon-btn" aria-label="Panier">
          <img src="/assets/icons/panier.png" alt="Panier" />
          <span class="navbar__badge" id="cart-count">0</span>
        </a>
        <a href="/favorites" class="navbar__icon-btn" aria-label="Favoris">
          <img src="/assets/icons/favori.png" alt="Favoris" />
          <span class="navbar__badge" id="fav-count">0</span>
        </a>
        <button class="navbar__burger" id="btn-burger" aria-label="Menu">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>

    <div class="search-bar" id="search-bar">
      <div class="search-bar__inner">
        <img src="/assets/icons/search.png" alt="" class="search-bar__icon" id="btn-search-submit" />
        <input type="text" id="search-input" class="search-bar__input"
          placeholder="Rechercher un club, une sélection, une compétition…" autocomplete="off" />
        <button class="search-bar__close" id="btn-search-close" aria-label="Fermer">✕</button>
      </div>
    </div>
  </header>

  <div class="catalogue-layout">

    <!-- ── Sidebar ── -->
    <aside class="sidebar">

      <!-- Prix -->
      <div class="sidebar__block">
        <h3 class="sidebar__title">Filtrer par prix</h3>
        <div class="price-range__labels">
          <span id="price-min-label">15 €</span>
          <span id="price-max-label">35 €</span>
        </div>
        <div class="price-range__slider">
          <div class="range-track">
            <div class="range-track__fill" id="range-fill"></div>
          </div>
          <input type="range" id="range-min" class="range-input" min="0" max="35" value="15" step="1" />
          <input type="range" id="range-max" class="range-input" min="0" max="35" value="35" step="1" />
        </div>
        <button class="sidebar__apply-btn" id="btn-apply-price">Filtrer</button>
      </div>

      <!-- Taille -->
      <div class="sidebar__block">
        <h3 class="sidebar__title">Taille</h3>
        <div class="size-filter">
          <button class="size-btn" data-size="S">S</button>
          <button class="size-btn" data-size="M">M</button>
          <button class="size-btn" data-size="L">L</button>
          <button class="size-btn" data-size="XL">XL</button>
          <button class="size-btn" data-size="XXL">XXL</button>
        </div>
      </div>

      <!-- Type — un seul actif à la fois -->
      <div class="sidebar__block">
        <h3 class="sidebar__title">Type</h3>
        <div class="type-filter">
          <button class="type-btn" data-type="domicile">Domicile</button>
          <button class="type-btn" data-type="extérieur">Extérieur</button>
          <button class="type-btn" data-type="gardien">Gardien</button>
          <button class="type-btn" data-type="third">Third</button>
        </div>
      </div>

      <!-- Couleur — sélection multiple -->
      <div class="sidebar__block">
        <h3 class="sidebar__title">Couleur</h3>
        <div class="color-filter">
          <button class="color-btn" data-color="Blanc">
            <span class="color-swatch" style="background:#FFFFFF;border:1px solid rgba(226,232,240,0.3)"></span>Blanc
          </button>
          <button class="color-btn" data-color="Noir">
            <span class="color-swatch" style="background:#111111"></span>Noir
          </button>
          <button class="color-btn" data-color="Rouge">
            <span class="color-swatch" style="background:#CC0000"></span>Rouge
          </button>
          <button class="color-btn" data-color="Bleu">
            <span class="color-swatch" style="background:#003087"></span>Bleu
          </button>
          <button class="color-btn" data-color="Bleu marine">
            <span class="color-swatch" style="background:#001F5B"></span>Bleu marine
          </button>
          <button class="color-btn" data-color="Vert">
            <span class="color-swatch" style="background:#006400"></span>Vert
          </button>
          <button class="color-btn" data-color="Jaune">
            <span class="color-swatch" style="background:#FFD700;border:1px solid rgba(226,232,240,0.2)"></span>Jaune
          </button>
          <button class="color-btn" data-color="Violet">
            <span class="color-swatch" style="background:#5B2D8E"></span>Violet
          </button>
          <button class="color-btn" data-color="Orange">
            <span class="color-swatch" style="background:#FF6600"></span>Orange
          </button>
          <button class="color-btn" data-color="Or">
            <span class="color-swatch" style="background:#CFB53B;border:1px solid rgba(226,232,240,0.2)"></span>Or
          </button>
          <button class="color-btn" data-color="Rose">
            <span class="color-swatch" style="background:#FF69B4"></span>Rose
          </button>
        </div>
      </div>

      <button class="sidebar__reset-btn" id="btn-reset">Réinitialiser les filtres</button>

    </aside>

    <!-- ── Catalogue ── -->
    <main class="catalogue-main">

      <nav class="breadcrumb">
        <a href="/">Accueil</a>
        <span>›</span>
        <span id="breadcrumb-label">Catalogue</span>
      </nav>

      <h1 class="catalogue-title" id="catalogue-title">Tous les maillots</h1>

      <div class="catalogue-bar">
        <p class="catalogue-bar__count" id="results-count"></p>
        <div class="catalogue-bar__sort">
          <label for="sort-select">Tri par</label>
          <select id="sort-select" class="sort-select">
            <option value="">ID</option>
            <option value="prix-asc">Prix croissant</option>
            <option value="prix-desc">Prix décroissant</option>
            <option value="nom-asc">Nom A → Z</option>
            <option value="nom-desc">Nom Z → A</option>
          </select>
        </div>
      </div>

      <div class="products-grid" id="products-grid">
        <div class="loader" id="loader">
          <div class="loader__spinner"></div>
          <p>Chargement des maillots…</p>
        </div>
      </div>

      <div class="pagination" id="pagination"></div>

    </main>
  </div>

  <footer class="footer">
    <div class="footer__inner">
      <div class="footer__brand">
        <img src="/assets/img/konekt.png" alt="Konekt" class="footer__logo" />
        <p class="footer__tagline">L'élite du handball, à portée de main.</p>
      </div>
      <div class="footer__links">
        <span class="footer__col-title">Catégories</span>
        <a href="/products?competition=EHF+Champions+League">EHF Champions League</a>
        <a href="/products?competition=Liqui+Moly+Starligue">Liqui Moly StarLigue</a>
        <a href="/products?club=France">Équipe de France</a>
        <a href="/products?club=Allemagne">Équipe d'Allemagne</a>
      </div>
      <div class="footer__links">
        <span class="footer__col-title">Mon compte</span>
        <a href="/cart">Mon panier</a>
        <a href="/favorites">Mes favoris</a>
      </div>
    </div>
    <div class="footer__bottom">
      <p>© Konekt Handball Kits 2026. Tous droits réservés.</p>
    </div>
  </footer>

  <script src="/src/products.js"></script>
</body>
</html>